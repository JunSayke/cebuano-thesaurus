{
  "name": "@junsayke/cebuano-thesaurus",
  "type": "module",
  "version": "1.0.0",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "description": "A thesaurus for the Cebuano language, providing synonyms and related words.",
  "author": "Antonio Ubaldo <antonio.junjr@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/junsayke/cebuano-thesaurus#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/junsayke/cebuano-thesaurus.git"
  },
  "bugs": {
    "url": "https://github.com/junsayke/cebuano-thesaurus/issues"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "data/database/wolff.sqlite"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build",
    "db:migrate": "node --experimental-strip-types scripts/migrate.ts",
    "db:generate": "kysely-codegen --dialect sqlite --url data/database/wolff.sqlite --out-file src/types/database.ts"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "bumpp": "^11.0.1",
    "kysely-codegen": "^0.20.0",
    "ts-node": "^10.9.2",
    "tsdown": "^0.21.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.8.0",
    "fast-xml-parser": "^5.5.9",
    "kysely": "^0.28.14"
  }
}
